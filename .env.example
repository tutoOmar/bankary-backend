# ==============================================================================
# BANKARY PROJECT - ENVIRONMENT VARIABLES EXAMPLE
# Rename this file to .env and fill in the values for local development.
# ==============================================================================

# GLOBAL DATABASE CONFIGURATION (Default used if not overridden per service)
DB_USERNAME=postgres
DB_PASSWORD=postgres

# RABBITMQ CONFIGURATION
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# ------------------------------------------------------------------------------
# CLIENTE-SERVICE
# ------------------------------------------------------------------------------
CLIENTE_APP_NAME=cliente-service
CLIENTE_SERVER_PORT=8080
CLIENTE_DB_URL=jdbc:postgresql://localhost:5432/cliente_db

# ------------------------------------------------------------------------------
# CUENTA-SERVICE
# ------------------------------------------------------------------------------
CUENTA_APP_NAME=cuenta-service
CUENTA_SERVER_PORT=8081
CUENTA_DB_URL=jdbc:postgresql://localhost:5432/cuenta_db
CLIENTE_SERVICE_URL=http://localhost:8080
